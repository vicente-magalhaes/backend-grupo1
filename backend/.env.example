# ==========================================
# CNH Connect - Variáveis de Ambiente
# ==========================================

# ── Supabase ─────────────────────────────
# URL do projeto no Supabase (ex: https://xyzcompany.supabase.co)
SUPABASE_URL=cole_sua_url_aqui
# Chave de serviço (service_role key) — ATENÇÃO: possui acesso total, bypassa RLS
# IMPORTANTE: use a chave LEGADA em formato JWT (começa com "eyJ..."), em
# Settings > API > "Legacy API keys". O formato novo "sb_secret_..." NÃO é aceito
# pela versão do supabase-py fixada no requirements.txt.
SUPABASE_SERVICE_ROLE_KEY=cole_sua_service_role_key_aqui

# ── Segurança / JWT ──────────────────────
JWT_SECRET=cole_seu_jwt_secret_aqui

# ── Aplicação ────────────────────────────
DEBUG=false
